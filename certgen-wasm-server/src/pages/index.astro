---
import BaseLayout from "../layouts/BaseLayout.astro";
import CertForm from "../components/molecules/CertForm.astro";
// Page: single-screen form + deployment hints (Atomic Design: molecules inside a page).
---

<BaseLayout title="WASM CertGen">
  <div class="container">
    <div class="panel" style="margin-bottom: 18px;">
      <div class="panelHeader">
        <div class="toolbar">
          <label for="langSelect" data-i18n="lang.label">Language</label>
          <select id="langSelect" aria-label="Language selector">
            <option value="en">EN</option>
            <option value="es">ES</option>
            <option value="pt">PT</option>
          </select>
        </div>
        <div class="kicker">Astro + Go WASM + Service Worker</div>
        <h1 class="title" data-i18n="hero.title">CertGen (offline) - generate your CA + server cert</h1>
        <p class="hint">
          <span data-i18n="hero.hint.before1">Fill</span> <code class="inline">domain</code>, <code class="inline">ip</code>
          <span data-i18n="hero.hint.before2">and</span> <code class="inline">org</code>.
          <span data-i18n="hero.hint.after1">Then download a</span> <code class="inline">certs.zip</code>
          <span data-i18n="hero.hint.after2">with</span> <code class="inline">certs/</code>.
        </p>
      </div>
      <div class="panelBody">
        <div class="grid">
          <section class="panel">
            <div class="panelHeader">
              <div class="kicker" data-i18n="form.kicker">Form</div>
              <h2 class="title" style="font-size: 1.25rem;" data-i18n="form.title">Certificate data</h2>
              <p class="hint" data-i18n="form.subtitle">
                Validation runs in browser and in WASM backend to avoid generation errors.
              </p>
            </div>
            <div class="panelBody">
              <CertForm />
            </div>
          </section>

          <aside class="panel">
            <div class="panelHeader">
              <p class="projectLinks">
                <a href="https://www.asterisk.org/" target="_blank" rel="noopener noreferrer">Asterisk</a>
                <span>•</span>
                <a href="https://www.freepbx.org/" target="_blank" rel="noopener noreferrer">FreePBX</a>
                <span>•</span>
                <a href="https://www.issabel.org/" target="_blank" rel="noopener noreferrer">IssabelPBX</a>
                <span>•</span>
                <a href="https://vitalpbx.com/" target="_blank" rel="noopener noreferrer">VitalPBX</a>
              </p>
              <h2 class="title" style="font-size: 1.25rem;" data-i18n="side.title">Which file goes where?</h2>
              <p class="hint">
                <span data-i18n="side.subtitle">These files are generated inside</span> <code class="inline">certs/</code>.
              </p>
            </div>
            <div class="panelBody">
              <div class="list">
                <div class="item">
                  <div class="name"><code class="inline">server.crt</code></div>
                  <div class="desc" data-i18n="file.servercrt">Server certificate (public part).</div>
                </div>
                <div class="item">
                  <div class="name"><code class="inline">server.key</code></div>
                  <div class="desc" data-i18n="file.serverkey">Server private key (secret).</div>
                </div>
                <div class="item">
                  <div class="name"><code class="inline">ca.crt</code></div>
                  <div class="desc" data-i18n="file.cacrt">CA that signed the server cert (chain).</div>
                </div>
                <div class="item">
                  <div class="name"><code class="inline">ca.key</code></div>
                  <div class="desc" data-i18n="file.cakey">CA private key (VERY secret, do not upload).</div>
                </div>
                <div class="item">
                  <div class="name"><code class="inline">fullchain.crt</code></div>
                  <div class="desc" data-i18n="file.fullchain">
                    Server cert + CA cert in one file (useful for some systems).
                  </div>
                </div>
              </div>

              <div class="divider"></div>

              <div class="miniTitle" data-i18n="validity.title">Certificate validity</div>
              <ul class="bullets">
                <li data-i18n="validity.ca">CA certificate (ca.crt): 10 years</li>
                <li data-i18n="validity.server">Server certificate (server.crt): 5 years</li>
              </ul>
              <p class="hint" style="margin-top: 8px;" data-i18n="validity.note">
                These validity periods are enforced by the WASM backend during generation.
              </p>

              <div class="divider"></div>

              <div class="miniTitle" data-i18n="vital.title">VitalPBX example</div>
              <ul class="bullets">
                <li><b>Certificate</b>: <code class="inline">server.crt</code></li>
                <li><b>Key</b>: <code class="inline">server.key</code></li>
                <li><b>Chain</b>: <code class="inline">ca.crt</code></li>
              </ul>
              <p class="hint" style="margin-top: 8px;" data-i18n="mapping.note">
                Use this mapping in platforms that ask for Certificate / Key / Chain fields (Asterisk, FreePBX,
                IssabelPBX, VitalPBX).
              </p>

              <div class="divider"></div>

              <div class="miniTitle">Install CA manually</div>
              <p class="hint" style="margin-top: 6px;">
                Open a step-by-step modal to install <code class="inline">ca.crt</code> on each OS.
              </p>
              <button id="openInstallModal" class="openModalBtn" type="button">Open install guide</button>
            </div>
          </aside>
        </div>
      </div>
    </div>
  </div>

  <dialog id="installModal" class="installModal">
    <div class="modalHeader">
      <h3>Install <code class="inline">ca.crt</code></h3>
      <button id="closeInstallModal" class="closeBtn" type="button" aria-label="Close">x</button>
    </div>

    <div class="tabs" role="tablist" aria-label="Install options">
      <button class="tabBtn isActive" type="button" role="tab" data-tab-target="winPanel">Windows</button>
      <button class="tabBtn" type="button" role="tab" data-tab-target="linuxPanel">Linux</button>
      <button class="tabBtn" type="button" role="tab" data-tab-target="macPanel">macOS</button>
      <button class="tabBtn" type="button" role="tab" data-tab-target="scriptPanel">Script</button>
    </div>

    <section id="winPanel" class="tabPanel isActive" role="tabpanel">
      <h4>Install from PowerShell (without script)</h4>
      <ol>
        <li>Open PowerShell as Administrator.</li>
        <li>Go to the extracted cert folder:</li>
      </ol>
      <pre><code>cd "C:\Users\$env:USERNAME\Downloads\certs"</code></pre>
      <ol start="3">
        <li>Install <code class="inline">ca.crt</code>:</li>
      </ol>
      <pre><code>Import-Certificate -FilePath ".\ca.crt" -CertStoreLocation "Cert:\LocalMachine\Root"</code></pre>
      <ol start="4">
        <li>Validate installation:</li>
      </ol>
      <pre><code>$thumb = (Get-PfxCertificate ".\ca.crt").Thumbprint
Get-ChildItem "Cert:\LocalMachine\Root" | Where-Object &#123; $_.Thumbprint -eq $thumb &#125;</code></pre>
    </section>

    <section id="linuxPanel" class="tabPanel" role="tabpanel" hidden>
      <h4>Linux (manual commands)</h4>
      <p>Debian/Ubuntu/Alpine style:</p>
      <pre><code>cd ~/Downloads/certs
sudo cp ca.crt /usr/local/share/ca-certificates/ca.crt
sudo update-ca-certificates</code></pre>
      <p>RHEL/CentOS/Fedora style:</p>
      <pre><code>cd ~/Downloads/certs
sudo cp ca.crt /etc/pki/ca-trust/source/anchors/ca.crt
sudo update-ca-trust extract</code></pre>
      <p>Quick validation:</p>
      <pre><code>openssl x509 -in ca.crt -noout -fingerprint -sha256</code></pre>
    </section>

    <section id="macPanel" class="tabPanel" role="tabpanel" hidden>
      <h4>macOS (manual commands)</h4>
      <ol>
        <li>Open Terminal.</li>
        <li>Go to the extracted cert folder:</li>
      </ol>
      <pre><code>cd ~/Downloads/certs</code></pre>
      <ol start="3">
        <li>Install certificate into System keychain:</li>
      </ol>
      <pre><code>sudo security add-trusted-cert -d -r trustRoot -k /Library/Keychains/System.keychain ./ca.crt</code></pre>
      <ol start="4">
        <li>Validate certificate is present:</li>
      </ol>
      <pre><code>sudo security find-certificate -a -Z /Library/Keychains/System.keychain | grep -i "$(openssl x509 -in ./ca.crt -noout -fingerprint -sha256 | awk -F= '&#123;print $2&#125;' | tr -d ':')"</code></pre>
    </section>

    <section id="scriptPanel" class="tabPanel" role="tabpanel" hidden>
      <h4>Use helper script</h4>
      <p>This project includes <code class="inline">install_ca_cert.sh</code> with cross-platform logic.</p>
      <pre><code>cd ~/Downloads/certs
chmod +x ./install_ca_cert.sh
./install_ca_cert.sh</code></pre>
      <a class="downloadBtn" href="/install_ca_cert.sh" download="install_ca_cert.sh">Download script</a>
    </section>
  </dialog>
</BaseLayout>

<script is:inline>
  // Modal + tabs controller (client side only).
  const openInstallModalBtn = document.getElementById("openInstallModal");
  const closeInstallModalBtn = document.getElementById("closeInstallModal");
  const installModal = document.getElementById("installModal");
  const tabButtons = Array.from(document.querySelectorAll(".tabBtn"));
  const tabPanels = Array.from(document.querySelectorAll(".tabPanel"));

  function activateTab(targetId) {
    tabButtons.forEach((btn) => {
      const isActive = btn.dataset.tabTarget === targetId;
      btn.classList.toggle("isActive", isActive);
      btn.setAttribute("aria-selected", String(isActive));
    });

    tabPanels.forEach((panel) => {
      const isActive = panel.id === targetId;
      panel.classList.toggle("isActive", isActive);
      panel.hidden = !isActive;
    });
  }

  if (openInstallModalBtn && installModal) {
    openInstallModalBtn.addEventListener("click", () => installModal.showModal());
  }
  if (closeInstallModalBtn && installModal) {
    closeInstallModalBtn.addEventListener("click", () => installModal.close());
  }
  if (installModal) {
    installModal.addEventListener("click", (event) => {
      const rect = installModal.getBoundingClientRect();
      const inside =
        event.clientX >= rect.left &&
        event.clientX <= rect.right &&
        event.clientY >= rect.top &&
        event.clientY <= rect.bottom;
      if (!inside) installModal.close();
    });
  }

  tabButtons.forEach((btn) => {
    btn.addEventListener("click", () => {
      activateTab(btn.dataset.tabTarget);
    });
  });
</script>

<style>
  .toolbar {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: 8px;
    margin-bottom: 8px;
    color: rgba(255, 255, 255, 0.78);
    font-size: 0.9rem;
  }
  .toolbar select {
    background: rgba(255, 255, 255, 0.1);
    color: rgba(255, 255, 255, 0.92);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 10px;
    padding: 6px 8px;
  }
  .list {
    display: grid;
    gap: 10px;
  }
  .projectLinks {
    margin: 6px 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 6px 10px;
    font-size: 0.88rem;
    color: rgba(255, 255, 255, 0.78);
  }
  .projectLinks a {
    color: rgba(128, 255, 234, 0.95);
    text-decoration: none;
  }
  .projectLinks a:hover {
    text-decoration: underline;
  }
  .item {
    padding: 12px;
    border-radius: 14px;
    border: 1px solid rgba(255, 255, 255, 0.14);
    background: rgba(255, 255, 255, 0.05);
  }
  .name {
    font-weight: 800;
    margin-bottom: 6px;
  }
  .desc {
    color: rgba(255, 255, 255, 0.72);
    font-size: 0.95rem;
  }
  .divider {
    height: 1px;
    background: rgba(255, 255, 255, 0.12);
    margin: 14px 0;
  }
  .miniTitle {
    font-weight: 800;
    letter-spacing: -0.01em;
    margin-top: 10px;
  }
  .bullets {
    margin: 8px 0 0;
    padding-left: 18px;
    color: rgba(255, 255, 255, 0.82);
  }
  .openModalBtn {
    margin-top: 10px;
    width: 100%;
    border: 1px solid rgba(255, 255, 255, 0.2);
    background: rgba(255, 255, 255, 0.08);
    color: rgba(255, 255, 255, 0.92);
    border-radius: 12px;
    padding: 10px 12px;
    font-weight: 700;
    cursor: pointer;
  }
  .installModal {
    width: min(900px, 92vw);
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 16px;
    background: #111a2a;
    color: rgba(255, 255, 255, 0.92);
    padding: 0;
  }
  .installModal::backdrop {
    background: rgba(0, 0, 0, 0.6);
  }
  .modalHeader {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 16px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.14);
  }
  .closeBtn {
    border: 1px solid rgba(255, 255, 255, 0.2);
    background: rgba(255, 255, 255, 0.08);
    color: rgba(255, 255, 255, 0.9);
    border-radius: 10px;
    width: 34px;
    height: 34px;
    cursor: pointer;
    font-weight: 700;
  }
  .tabs {
    display: flex;
    gap: 8px;
    padding: 12px 16px 0;
    flex-wrap: wrap;
  }
  .tabBtn {
    border: 1px solid rgba(255, 255, 255, 0.2);
    background: rgba(255, 255, 255, 0.07);
    color: rgba(255, 255, 255, 0.9);
    border-radius: 10px;
    padding: 8px 12px;
    cursor: pointer;
    font-weight: 700;
  }
  .tabBtn.isActive {
    background: rgba(128, 255, 234, 0.2);
    border-color: rgba(128, 255, 234, 0.5);
  }
  .tabPanel {
    padding: 14px 16px 16px;
  }
  .tabPanel h4 {
    margin: 0 0 10px;
  }
  .tabPanel pre {
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 10px;
    padding: 10px 12px;
    overflow: auto;
    margin-top: 6px;
  }
  .downloadBtn {
    display: inline-block;
    margin-top: 8px;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 10px;
    padding: 8px 12px;
    text-decoration: none;
    font-weight: 700;
    background: rgba(255, 255, 255, 0.08);
  }
</style>

